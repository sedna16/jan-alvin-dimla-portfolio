var modal_image_src = "";

---

<script>

    //
    //
    function init_image_triggers() {

        //
        //
        const image_triggers = document.querySelectorAll('.image_modal_thumb');
        var show_modal = true;
        var modal_image_src = "";
        var modal_element = document.getElementById("image_modal_container");

        //
        //
        image_triggers.forEach(link => {

            //
            //
            link.addEventListener('click', function(event) {
                
                //
                //
                event.preventDefault(); // Prevent the link from navigating

                //
                // Get the data attributes using the dataset property
                const clicked_image = this.dataset.image;
                modal_image_src = clicked_image;
                const imgElement = document.getElementById("modal_image");
                imgElement.src = modal_image_src;

                //
                //
                modal_element.classList.add("d-block");
            });

        });

        //
        //
        document.getElementById("close_modal_btn").addEventListener("click", function() {
            modal_element.classList.remove("d-block");
        });

    }

    init_image_triggers();    

</script>

{loop_items.map((item) => (

    <section class={item.bg_class}>
        <div class="container py-5">

            <div class="d-block text-center mb-3">
                <h2 class="title display-4">{item.title}</h2>
            </div>

            {item.direction == "right" ? 
            <div class="row align-items-center mb-5">
                <div class="col-lg-6 mb-3 text-center">
                    <a href="#" class="image_modal_thumb" data-image={item.link}>
                        <img src={item.image} alt={item.title} class="img-fluid object-fit-contain">
                    </a>
                    <small>Click for fullview</small>
                </div>
                <div class="col-lg-6 mb-3">
                    <p class="text-justify" set:html={item.description} />
                </div>
            </div>
            : 
            <div class="row align-items-center mb-5">
                <div class="col-lg-6 mb-3">
                    <p class="text-justify" set:html={item.description} />
                </div>
                <div class="col-lg-6 mb-3 text-center">
