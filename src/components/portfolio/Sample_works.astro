    </section>

))}

<div class="modal fade show" id="image_modal_container" style="background-color: rgba(0, 0, 0, 0.7);">
    <div class="modal-dialog modal-xl">
        <div class="modal-content rounded-0">

            <div class="modal-header">
                <button id="close_modal_btn" type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <img src="" class="img-fluid object-fit-contain" id="modal_image">
            </div>

        </div>
    </div>
</div>

