<section class="works py-5">
    <div class="container p-5">

        <h2 class="text-center display-block mb-5">My Works</h2>

        {works.map((work) => (

            <div class="row">
                {work.map((project) => (

                    <div class="col-12 col-md-6 col-lg-3 mb-3">
                        <div class="card h-100 mb-0 p-0">
                            <div class="text-center">
                                <img src={project.image} alt={project.title} style="width:100%;height:auto;min-width:20px;min-height:20px;">
                            </div>
                            <h4 class="text-center display-block p-3">{project.title}</h4>
                        </div>
                    </div>

                ))}
