<section class="contact-form dotted-background py-5">
    <div class="container p-5 text-white">
        <div class="display-block px-3">
            <div class="card p-4" style="max-width: 700px; margin: 0 auto; border: none;">

                <h2 class="text-center display-block mb-5">Contact Me</h2>

                <form action="https://api.web3forms.com/submit" method="POST">
                    <input type="hidden" name="access_key" value="ee6e5304-65dd-41ef-8dd5-9abe89f05275">
                    
                    <div class="mb-3">
                        <label for="exampleFormControlInput1" class="form-label">Your Name</label>
                        <input type="text" name="name" class="form-control" id="exampleFormControlInput1" placeholder="Your Name" required>
                    </div>
                    <div class="mb-3">
                        <label for="exampleFormControlInput2" class="form-label">Your Email</label>
                        <input type="email" name="email" class="form-control" id="exampleFormControlInput2" placeholder="Your Email" required>
                    </div>
                    <div class="mb-3">
                        <label for="exampleFormControlTextarea1" class="form-label">Your Message</label>
                        <textarea class="form-control" name="message" id="exampleFormControlTextarea1" rows="3" placeholder="Your Message" required></textarea>
                    </div>

                    <div class="mb-3">  
                        <button type="submit" class="btn btn-success w-100">Submit</button>
                    </div>
                
                </form>

            </div>
        </div>
    </div>
</section>

